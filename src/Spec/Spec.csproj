<Project Sdk="Microsoft.NET.Sdk">

    <ItemGroup>
        <EmbeddedResource Include="embedded_resources\**\*"/>
    </ItemGroup>

    <Target Name="GenerateJsonSchema" AfterTargets="Build">
        <Exec Command="dotnet run --project $(MSBuildProjectDirectory)\..\Spec.SchemaGenerator.Cli\Spec.SchemaGenerator.Cli.csproj -- &quot;$(OutputPath)$(AssemblyName).dll&quot; &quot;$(SchemaOutputPath)&quot;"/>
        <Message Text="JSON schemas generated in: $(SchemaOutputPath)" Importance="high"/>
    </Target>

    <ItemGroup>
        <ProjectReference Include="..\Domain\Domain.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
        <PackageReference Include="Vecc.YamlDotNet.Analyzers.StaticGenerator"/>
        <PackageReference Include="YamlDotNet"/>
        <PackageReference Include="JsonSchema.Net"/>
        <PackageReference Include="JsonSchema.Net.Generation"/>
    </ItemGroup>

</Project>